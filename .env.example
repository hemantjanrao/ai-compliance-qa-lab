# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default models (cheap for dev, swap to bigger for prod evals)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini
# Embeddings: local (default, no API cost) or openai
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_MODEL=text-embedding-3-small

# Vector store
CHROMA_PATH=./chroma_db
COLLECTION_NAME=eu_ai_act

# Retrieval: basic (vector only) or advanced (hybrid BM25 + RRF + cross-encoder rerank)
RAG_RETRIEVAL_MODE=advanced
RAG_CANDIDATE_MULTIPLIER=4
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Langfuse (observability) - get free keys at cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Eval thresholds (used by CI gate)
FAITHFULNESS_THRESHOLD=0.80
ANSWER_RELEVANCE_THRESHOLD=0.80
CONTEXT_PRECISION_THRESHOLD=0.75
CONTEXT_RECALL_THRESHOLD=0.75
MAX_P95_LATENCY_MS=4000
